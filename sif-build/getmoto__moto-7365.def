Bootstrap: docker
From: ubuntu:22.04

%post
    set -eux
    test "$(uname -m)" = "aarch64"
    export DEBIAN_FRONTEND=noninteractive
    export TZ=Etc/UTC

    apt-get update
    apt-get install -y --no-install-recommends \
        bash \
        build-essential \
        ca-certificates \
        cargo \
        curl \
        file \
        git \
        jq \
        libffi-dev \
        libjpeg-dev \
        libssl-dev \
        libxml2-dev \
        libxslt1-dev \
        locales \
        make \
        patch \
        pkg-config \
        procps \
        rustc \
        tar \
        tzdata \
        wget \
        zlib1g-dev
    sed -i 's/^# *en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen
    locale-gen
    rm -rf /var/lib/apt/lists/*

    miniforge=/tmp/Miniforge3-Linux-aarch64.sh
    curl -fL \
        https://github.com/conda-forge/miniforge/releases/download/26.3.2-2/Miniforge3-26.3.2-2-Linux-aarch64.sh \
        -o "$miniforge"
    echo "f4096a92482b30f04534cddb63d8bc929118318deffac71d90fb89dc52359d22  $miniforge" \
        | sha256sum -c -
    bash "$miniforge" -b -p /opt/miniconda3
    rm -f "$miniforge"
    /opt/miniconda3/bin/conda create -y -n testbed python=3.12 pip

    git clone https://github.com/getmoto/moto.git /testbed
    git -C /testbed checkout --detach 7f6c9cb1deafb280fe7fcc7551c38e397f11a706
    git -C /testbed remote remove origin
    git config --system --add safe.directory /testbed

    export PATH=/opt/miniconda3/envs/testbed/bin:/opt/miniconda3/bin:$PATH
    export PIP_DISABLE_PIP_VERSION_CHECK=1
    export PIP_NO_CACHE_DIR=1
    make -C /testbed init
    python -c "import boto3, moto, pytest; print('moto sandbox dependencies: OK')"

    git -C /testbed reset --hard 7f6c9cb1deafb280fe7fcc7551c38e397f11a706
    git -C /testbed clean -fdx
    git -C /testbed status --short
    chmod -R a+rwX /testbed
    /opt/miniconda3/bin/conda clean -afy
    apt-get purge -y \
        build-essential \
        cargo \
        libffi-dev \
        libjpeg-dev \
        libssl-dev \
        libxml2-dev \
        libxslt1-dev \
        pkg-config \
        rustc \
        zlib1g-dev
    apt-get autoremove -y
    apt-get clean
    rm -rf /var/lib/apt/lists/*
    rm -rf /root/.cache /tmp/*

    printf '%s\n' \
        'instance_id=getmoto__moto-7365' \
        'repo=getmoto/moto' \
        'base_commit=7f6c9cb1deafb280fe7fcc7551c38e397f11a706' \
        'python=3.12' \
        'architecture=arm64' \
        >/etc/polar-sandbox-release

%environment
    export PATH=/opt/miniconda3/envs/testbed/bin:/opt/miniconda3/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export CONDA_DEFAULT_ENV=testbed
    export LANG=en_US.UTF-8
    export LC_ALL=en_US.UTF-8
    export PYTHONUNBUFFERED=1
    export PIP_DISABLE_PIP_VERSION_CHECK=1

%test
    set -eu
    test "$(uname -m)" = "aarch64"
    test "$(git -C /testbed rev-parse HEAD)" = "7f6c9cb1deafb280fe7fcc7551c38e397f11a706"
    test "$(/opt/miniconda3/envs/testbed/bin/python -c 'import platform; print(platform.machine())')" = "aarch64"
    /opt/miniconda3/envs/testbed/bin/python -c "import boto3, moto, pytest"
    cd /testbed
    /opt/miniconda3/envs/testbed/bin/python -m pytest -q \
        tests/test_dynamodb/test_dynamodb_update_expressions.py::test_update_different_map_elements_in_single_request

%startscript
    exec sleep infinity

%runscript
    if [ "$#" -eq 0 ]; then
        exec /bin/bash
    fi
    exec "$@"

%labels
    org.opencontainers.image.title "Polar SWE-Gym sandbox getmoto__moto-7365"
    org.opencontainers.image.description "Native ARM64 sandbox for Polar/Slime SWE-Gym smoke rollout"
    org.opencontainers.image.architecture "arm64"
    org.opencontainers.image.source "https://github.com/getmoto/moto"
    org.opencontainers.image.revision "7f6c9cb1deafb280fe7fcc7551c38e397f11a706"
    io.polar.instance-id "getmoto__moto-7365"
